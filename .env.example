# .env.example — skopiuj do .env

# Baza danych (wymagane)
DATABASE_URL=postgresql://user:password@localhost:5432/techtrends

# GitHub API token (wymagane do enrichment)
# Wygeneruj na: github.com/settings/tokens
# Scope: public_repo (read-only wystarczy)
# Limit: 5000 req/h przy tokenie (vs 60/h bez)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Next.js ISR revalidation (opcjonalne dla seed)
REVALIDATE_SECRET=your-random-secret-here
